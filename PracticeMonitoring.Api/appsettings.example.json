{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=practice_monitoring_db;Username=<DB_USER>;Password=<DB_PASSWORD>"
  },
  "Jwt": {
    "Key": "<LONG_RANDOM_SECRET_AT_LEAST_32_CHARS>",
    "Issuer": "PracticeMonitoring.Api",
    "Audience": "PracticeMonitoring.Client",
    "ExpiresMinutes": "120"
  },
  "PgTools": {
    "PgDumpPath": "<PATH_TO_PG_DUMP>",
    "PgRestorePath": "<PATH_TO_PG_RESTORE>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
