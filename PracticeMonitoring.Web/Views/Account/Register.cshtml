@model PracticeMonitoring.Web.Models.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="loginwrap">
    <div class="loginblock registerblock">
        <h1 class="login-title">Регистрация</h1>
        <p class="login-subtitle">Создайте новую учетную запись</p>

        @if (ViewBag.Error != null)
        {
            <div class="validation-error">@ViewBag.Error</div>
        }

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form asp-action="Register" method="post" class="auth-form" id="registerForm" novalidate>
            <div class="form-group">
                <label asp-for="Surname" class="form-label">Фамилия</label>
                <input asp-for="Surname" class="form-input" placeholder="Введите фамилию" />
                <span asp-validation-for="Surname" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Name" class="form-label">Имя</label>
                <input asp-for="Name" class="form-input" placeholder="Введите имя" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Patronymic" class="form-label">Отчество (если есть)</label>
                <input asp-for="Patronymic" class="form-input" placeholder="Введите отчество" />
                <span asp-validation-for="Patronymic" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-input" placeholder="Введите email" autocomplete="username" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="specialtySelect">Специальность</label>

                <select id="specialtySelect" name="SpecialtyId" class="native-select-hidden">
                    <option value="">-- выберите специальность --</option>
                </select>

                <div class="custom-select" data-target="specialtySelect">
                    <button type="button" class="custom-select-trigger">-- выберите специальность --</button>
                    <div class="custom-select-menu"></div>
                </div>

                <span class="field-validation-error" id="specialtyError"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="groupSelect">Группа</label>

                <select id="groupSelect" name="GroupId" class="native-select-hidden">
                    <option value="">-- выберите группу --</option>
                </select>

                <div class="custom-select" data-target="groupSelect">
                    <button type="button" class="custom-select-trigger">-- выберите группу --</button>
                    <div class="custom-select-menu"></div>
                </div>

                <span class="field-validation-error" id="groupError"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="courseDisplay">Курс</label>
                <input id="courseDisplay" readonly class="form-input" placeholder="Курс определится автоматически" />
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="Введите пароль" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="login-button">Зарегистрироваться</button>
        </form>

        <div class="login-footer">
            Уже есть аккаунт?
            <a asp-action="Login" class="login-link">Вернуться ко входу</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
}