@model PracticeMonitoring.Web.Models.Auth.LoginViewModel

<div class="loginwrap">
    <div class="loginblock">
        <h1 class="login-title">Вход</h1>
        <p class="login-subtitle">Введите данные своей учетной записи</p>

        @if (ViewBag.Error != null)
        {
            <div class="validation-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-input" placeholder="Введите email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="Введите пароль" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="login-button">Войти</button>
        </form>

        <div class="login-footer">
            Нет аккаунта?
            <a asp-action="Register" class="login-link">Зарегистрироваться</a>
        </div>
    </div>
</div>