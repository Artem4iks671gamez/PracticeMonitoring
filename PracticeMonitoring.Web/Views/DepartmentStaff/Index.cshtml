@model PracticeMonitoring.Web.Models.DepartmentStaff.DepartmentStaffPageViewModel

@{
    ViewData["Title"] = "Работник отдела";
}

<link rel="stylesheet" href="~/css/DepartmentStaff.css" />

<div class="department-shell">
    <section class="department-hero-card">
        <div>
            <div class="department-badge">Работник отдела по производственному обучению</div>
            <h1 class="department-title">Модуль производственной практики</h1>
            <p class="department-subtitle">@Model.FullName</p>
        </div>

        <div class="department-hero-actions">
            <button type="button" class="department-secondary-button" id="openProfileSettingsButton">
                Профиль
            </button>
        </div>
    </section>

    @if (TempData["ProfileSuccess"] is string profileSuccess)
    {
        <div class="student-alert student-alert-success">@profileSuccess</div>
    }

    @if (TempData["ProfileError"] is string profileError)
    {
        <div class="student-alert student-alert-error">@profileError</div>
    }

    <div class="department-workspace">
        <aside class="department-sidebar-card">
            <div class="department-sidebar-block">
                <div class="department-sidebar-title">Навигация</div>

                <div class="department-sidebar-nav">
                    <button type="button" class="department-nav-button active" data-panel-target="practicesPanel">
                        Производственные практики
                    </button>

                    <button type="button" class="department-nav-button" data-panel-target="logsPanel">
                        Журнал изменений
                    </button>

                    <button type="button" class="department-nav-button" data-panel-target="supervisorsPanel">
                        Руководители
                    </button>

                    <button type="button" class="department-nav-button nav-button-with-badge" data-panel-target="chatsPanel">
                        <span>Чаты</span>
                        @if (Model.UnreadChatsCount > 0)
                        {
                            <span class="nav-unread-badge">@Model.UnreadChatsCount</span>
                        }
                    </button>

                    <button type="button" class="department-nav-button" data-panel-target="notificationsPanel">
                        Уведомления
                    </button>
                </div>
            </div>

            <div class="department-sidebar-divider"></div>

            <div class="department-sidebar-block">
                <div class="department-sidebar-title">Действия</div>

                <div class="department-sidebar-actions">
                    <button type="button" class="department-primary-button department-full-button" id="openCreatePracticeButton">
                        Создать практику
                    </button>

                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="department-secondary-button department-full-button">
                            Выйти
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <section class="department-main-card">
            <div class="department-panel active" id="practicesPanel">
                <div class="department-panel-header">
                    <div>
                        <h2>Производственные практики</h2>
                        <p>Создание, поиск, редактирование и контроль статуса практик.</p>
                    </div>
                </div>

                <div class="department-subtabs department-practice-status-tabs">
                    <button type="button" class="department-subtab-button active" data-practice-status="active">
                        Активные практики
                        <span class="department-subtab-counter">@Model.Practices.Count(x => !x.IsCompleted)</span>
                    </button>

                    <button type="button" class="department-subtab-button" data-practice-status="completed">
                        Завершившиеся практики
                        <span class="department-subtab-counter">@Model.Practices.Count(x => x.IsCompleted)</span>
                    </button>
                </div>

                <div class="department-toolbar">
                    <div class="department-toolbar-row">
                        <div class="department-search-wrap">
                            <input type="text"
                                   id="practiceSearchInput"
                                   class="form-input department-search-input"
                                   placeholder="Поиск по индексу ПП, названию, ПМ или специальности..." />
                        </div>

                        <div class="department-filter-wrap">
                            <select id="practiceSortSelect" class="native-select-hidden">
                                <option value="date-asc">Сначала ранние сроки</option>
                                <option value="date-desc">Сначала поздние сроки</option>
                                <option value="index-asc">Индекс ПП А-Я</option>
                                <option value="hours-desc">Больше часов выше</option>
                            </select>

                            <div class="custom-select" data-target="practiceSortSelect">
                                <button type="button" class="custom-select-trigger">Сначала ранние сроки</button>
                                <div class="custom-select-menu"></div>
                            </div>
                        </div>
                    </div>

                    <div class="department-toolbar-row department-toolbar-row-secondary">
                        <div class="department-filter-wrap">
                            <select id="specialtyFilterSelect" class="native-select-hidden">
                                <option value="">Все специальности</option>
                            </select>

                            <div class="custom-select" data-target="specialtyFilterSelect">
                                <button type="button" class="custom-select-trigger">Все специальности</button>
                                <div class="custom-select-menu"></div>
                            </div>
                        </div>

                        <div class="department-date-range">
                            <input type="date" id="dateFromFilter" class="form-input" />
                            <input type="date" id="dateToFilter" class="form-input" />
                        </div>
                    </div>
                </div>

                <div class="department-summary-bar">
                    <span id="practicesCountLabel">Показано практик: @Model.Practices.Count</span>
                </div>

                <div class="department-practices-list" id="practicesList">
                    @foreach (var practice in Model.Practices)
                    {
                        <article class="practice-card"
                                 data-id="@practice.Id"
                                 data-practice-index="@practice.PracticeIndex"
                                 data-name="@practice.Name"
                                 data-specialty-id="@practice.SpecialtyId"
                                 data-specialty-code="@practice.SpecialtyCode"
                                 data-specialty-name="@practice.SpecialtyName"
                                 data-professional-module-code="@practice.ProfessionalModuleCode"
                                 data-professional-module-name="@practice.ProfessionalModuleName"
                                 data-hours="@practice.Hours"
                                 data-start-date="@practice.StartDate.ToString("yyyy-MM-dd")"
                                 data-end-date="@practice.EndDate.ToString("yyyy-MM-dd")"
                                 data-students-count="@practice.AssignedStudentsCount"
                                 data-is-completed="@practice.IsCompleted.ToString().ToLower()">
                            <div class="practice-card-main">
                                <div class="practice-card-top">
                                    <div class="practice-card-title-block">
                                        <div class="practice-card-topline">
                                            <div class="practice-index-chip">@practice.PracticeIndex</div>
                                            <div class="practice-status-chip @(practice.IsCompleted ? "completed" : "active")">
                                                @(practice.IsCompleted ? "Завершилась" : "Активна")
                                            </div>
                                        </div>
                                        <h3 class="practice-card-name">@practice.Name</h3>
                                    </div>

                                    <div class="practice-card-side">
                                        <span class="practice-side-meta">@practice.Hours ч.</span>
                                        <span class="practice-side-meta">@practice.StartDate.ToString("dd.MM.yyyy") - @practice.EndDate.ToString("dd.MM.yyyy")</span>
                                    </div>
                                </div>

                                <div class="practice-card-meta-row">
                                    <div class="practice-meta-item">
                                        <span class="practice-meta-label">Специальность</span>
                                        <span class="practice-meta-value">@practice.SpecialtyCode @practice.SpecialtyName</span>
                                    </div>

                                    <div class="practice-meta-separator"></div>

                                    <div class="practice-meta-item">
                                        <span class="practice-meta-label">ПМ</span>
                                        <span class="practice-meta-value">@practice.ProfessionalModuleCode @practice.ProfessionalModuleName</span>
                                    </div>

                                    <div class="practice-meta-separator"></div>

                                    <div class="practice-meta-item">
                                        <span class="practice-meta-label">Назначено студентов</span>
                                        <span class="practice-meta-value">@practice.AssignedStudentsCount</span>
                                    </div>
                                </div>
                            </div>

                            <div class="practice-card-actions">
                                <button type="button" class="department-ghost-button practice-assignments-button">
                                    Назначение студентов
                                </button>

                                <button type="button" class="department-secondary-button practice-details-button">
                                    Сведения
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <div class="department-panel" id="logsPanel">
                <div class="department-panel-header">
                    <div>
                        <h2>Журнал изменений</h2>
                        <p>Аудит действий работников отдела по карточкам практик и назначениям студентов.</p>
                    </div>
                </div>

                <div class="department-subtabs">
                    <button type="button" class="department-subtab-button active" data-log-console="practiceChangesConsole">
                        Изменения практик
                        <span class="department-subtab-counter">@Model.PracticeChangeLogs.Count</span>
                    </button>

                    <button type="button" class="department-subtab-button" data-log-console="assignmentChangesConsole">
                        Назначения студентов
                        <span class="department-subtab-counter">@Model.AssignmentChangeLogs.Count</span>
                    </button>
                </div>

                <div class="department-console-wrapper">
                    <div class="department-console active" id="practiceChangesConsole">
                        <div class="department-console-body">
                            @if (Model.PracticeChangeLogs.Count == 0)
                            {
                                <div class="department-console-empty">Пока нет записей по карточкам практик.</div>
                            }
                            else
                            {
                                @foreach (var log in Model.PracticeChangeLogs)
                                {
                                    <div class="department-console-line">
                                        <span class="department-console-date">@log.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</span>
                                        <span class="department-console-text"><strong>@(log.ActorFullName ?? "Работник отдела")</strong>: @log.Description</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="department-console-footer">
                            <a asp-controller="DepartmentStaff" asp-action="DownloadLogs" asp-route-category="practice-changes" class="department-console-download-button">
                                Сохранить .txt
                            </a>
                        </div>
                    </div>

                    <div class="department-console" id="assignmentChangesConsole">
                        <div class="department-console-body">
                            @if (Model.AssignmentChangeLogs.Count == 0)
                            {
                                <div class="department-console-empty">Пока нет записей по назначениям студентов.</div>
                            }
                            else
                            {
                                @foreach (var log in Model.AssignmentChangeLogs)
                                {
                                    <div class="department-console-line">
                                        <span class="department-console-date">@log.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</span>
                                        <span class="department-console-text"><strong>@(log.ActorFullName ?? "Работник отдела")</strong>: @log.Description</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="department-console-footer">
                            <a asp-controller="DepartmentStaff" asp-action="DownloadLogs" asp-route-category="assignment-changes" class="department-console-download-button">
                                Сохранить .txt
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="department-panel" id="supervisorsPanel">
                <div class="department-panel-header">
                    <div>
                        <h2>Руководители</h2>
                        <p>Нагрузка по студентам и производственным практикам у руководителей от техникума.</p>
                    </div>
                </div>

                <div class="department-toolbar">
                    <div class="department-toolbar-row">
                        <div class="department-search-wrap">
                            <input type="text"
                                   id="supervisorSearchInput"
                                   class="form-input department-search-input"
                                   placeholder="Поиск по ФИО или email руководителя..." />
                        </div>

                        <div class="department-filter-wrap">
                            <select id="supervisorSortSelect" class="native-select-hidden">
                                <option value="name-asc">ФИО А-Я</option>
                                <option value="students-desc">Больше студентов</option>
                                <option value="practices-desc">Больше практик</option>
                            </select>

                            <div class="custom-select" data-target="supervisorSortSelect">
                                <button type="button" class="custom-select-trigger">ФИО А-Я</button>
                                <div class="custom-select-menu"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="department-summary-bar">
                    <span id="supervisorsCountLabel">Показано руководителей: @Model.Supervisors.Count</span>
                </div>

                <div class="department-supervisors-list" id="supervisorsList">
                    @foreach (var supervisor in Model.Supervisors)
                    {
                        <article class="supervisor-card"
                                 data-id="@supervisor.Id"
                                 data-full-name="@supervisor.FullName"
                                 data-email="@supervisor.Email"
                                 data-students-count="@supervisor.AssignedStudentsCount"
                                 data-practices-count="@supervisor.PracticesCount"
                                 data-avatar-url="@supervisor.AvatarUrl">
                            <div class="supervisor-card-main">
                                <div class="supervisor-card-header">
                                    <div class="supervisor-card-avatar">
                                        @if (!string.IsNullOrWhiteSpace(supervisor.AvatarUrl))
                                        {
                                            <img src="@supervisor.AvatarUrl" alt="Аватар руководителя" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrWhiteSpace(supervisor.FullName) ? "Р" : supervisor.FullName[0].ToString().ToUpper())
                                        }
                                    </div>
                                    <div class="supervisor-card-headline">
                                        <h3 class="supervisor-card-name">@supervisor.FullName</h3>
                                        <div class="supervisor-card-email">@supervisor.Email</div>
                                    </div>
                                </div>

                                <div class="supervisor-card-metrics">
                                    <div class="supervisor-card-metric">
                                        <span class="supervisor-card-metric-label">Назначено студентов</span>
                                        <span class="supervisor-card-metric-value">@supervisor.AssignedStudentsCount</span>
                                    </div>

                                    <div class="supervisor-card-metric">
                                        <span class="supervisor-card-metric-label">Практик в нагрузке</span>
                                        <span class="supervisor-card-metric-value">@supervisor.PracticesCount</span>
                                    </div>
                                </div>
                            </div>

                            <div class="supervisor-card-actions">
                                <button type="button" class="department-primary-button supervisor-details-button">
                                    Подробнее
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <div class="department-panel" id="chatsPanel">
                <div class="department-panel-header">
                    <div>
                        <h2>Чаты</h2>
                        <p>Диалоги со студентами, руководителями, работниками отдела и администраторами.</p>
                    </div>
                </div>

                @await Html.PartialAsync("_MessagingWorkspace", Model.Messaging)
            </div>

            <div class="department-panel" id="notificationsPanel">
                <div class="department-panel-header">
                    <div>
                        <h2>Уведомления</h2>
                        <p>Будущий центр событий по практикам, чатам и назначениям.</p>
                    </div>
                </div>

                @await Html.PartialAsync("_NotificationsPanel", Model.Notifications)
            </div>
        </section>
    </div>
</div>

<div class="department-modal-backdrop" id="supervisorDetailsModalBackdrop">
    <div class="department-modal department-modal-large department-modal-supervisor">
        <div class="department-modal-header">
            <div>
                <h2 id="supervisorDetailsTitle">Сведения о руководителе</h2>
                <p id="supervisorDetailsSubtitle">Нагрузка по студентам и производственным практикам.</p>
            </div>
            <button type="button" class="department-modal-close" id="closeSupervisorDetailsModalButton">?</button>
        </div>

        <div class="department-details-layout department-supervisor-layout">
            <section class="department-details-overview">
                <div class="department-details-overview-main">
                    <div class="department-details-overview-label">Руководитель</div>
                    <div class="department-details-overview-title" id="supervisorDetailsOverviewTitle">
                        Выберите руководителя
                    </div>
                    <div class="department-details-overview-subtitle" id="supervisorDetailsOverviewSubtitle">
                        Здесь будет собрана текущая нагрузка по студентам и практикам.
                    </div>
                </div>

                <div class="department-details-overview-stats" id="supervisorDetailsOverviewStats"></div>
            </section>

            <div class="department-subtabs">
                <button type="button" class="department-subtab-button active" data-supervisor-details-tab="students">
                    Студенты
                    <span class="department-subtab-counter" id="supervisorStudentsTabCounter">0</span>
                </button>

                <button type="button" class="department-subtab-button" data-supervisor-details-tab="practices">
                    Производственные практики преподавателя
                    <span class="department-subtab-counter" id="supervisorPracticesTabCounter">0</span>
                </button>
            </div>

            <div class="department-supervisor-tab-content active" id="supervisorStudentsTab">
                <div class="department-details-section">
                    <div class="department-details-title">Студенты руководителя</div>
                    <div id="supervisorDetailsStudents" class="department-details-list"></div>
                </div>
            </div>

            <div class="department-supervisor-tab-content" id="supervisorPracticesTab">
                <div class="department-details-section">
                    <div class="department-details-title">Производственные практики преподавателя</div>
                    <div id="supervisorDetailsPractices" class="department-details-list"></div>
                </div>
            </div>
        </div>

        <div class="department-modal-actions">
            <button type="button" class="department-primary-button" id="closeSupervisorDetailsFooterButton">
                Закрыть
            </button>
        </div>
    </div>
</div>

<div class="department-modal-backdrop" id="practiceEditModalBackdrop">
    <div class="department-modal department-modal-large">
        <div class="department-modal-header">
            <div>
                <h2 id="practiceEditModalTitle">Создание производственной практики</h2>
                <p id="practiceEditModalSubtitle">Заполните основную информацию, компетенции и назначения.</p>
            </div>
            <button type="button" class="department-modal-close" id="closePracticeEditModalButton">?</button>
        </div>

        <form id="practiceForm" class="department-form" novalidate>
            <input type="hidden" id="practiceId" />

            <div class="department-form-global-error" id="practiceGlobalError"></div>

            <div class="department-form-section">
                <div class="department-form-section-title">Основная информация</div>

                <div class="department-form-grid">
                    <div class="form-group">
                        <label class="form-label" for="practiceIndex">Индекс ПП</label>
                        <input class="form-input" type="text" id="practiceIndex" />
                        <div class="field-error" data-error-for="PracticeIndex"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="practiceName">Название ПП</label>
                        <input class="form-input" type="text" id="practiceName" />
                        <div class="field-error" data-error-for="Name"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="practiceSpecialtySelect">Специальность</label>
                        <select id="practiceSpecialtySelect" class="native-select-hidden">
                            <option value="">-- выберите специальность --</option>
                        </select>

                        <div class="custom-select" data-target="practiceSpecialtySelect">
                            <button type="button" class="custom-select-trigger">-- выберите специальность --</button>
                            <div class="custom-select-menu"></div>
                        </div>

                        <div class="field-error" data-error-for="SpecialtyId"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="practiceHours">Количество часов</label>
                        <input class="form-input" type="number" id="practiceHours" min="1" />
                        <div class="field-error" data-error-for="Hours"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="professionalModuleCode">Код профессионального модуля</label>
                        <input class="form-input" type="text" id="professionalModuleCode" />
                        <div class="field-error" data-error-for="ProfessionalModuleCode"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="professionalModuleName">Название профессионального модуля</label>
                        <input class="form-input" type="text" id="professionalModuleName" />
                        <div class="field-error" data-error-for="ProfessionalModuleName"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="practiceStartDate">Дата начала</label>
                        <input class="form-input" type="date" id="practiceStartDate" />
                        <div class="field-error" data-error-for="StartDate"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="practiceEndDate">Дата окончания</label>
                        <input class="form-input" type="date" id="practiceEndDate" />
                        <div class="field-error" data-error-for="EndDate"></div>
                    </div>
                </div>
            </div>

            <div class="department-form-section">
                <div class="department-form-section-header">
                    <div class="department-form-section-title">Профессиональные компетенции и виды работ</div>
                    <button type="button" class="department-ghost-button" id="addCompetencyButton">
                        Добавить компетенцию
                    </button>
                </div>

                <div class="field-error field-error-block" data-error-for="Competencies"></div>
                <div id="competenciesContainer" class="department-repeaters-container"></div>
            </div>

            <div class="department-modal-actions">
                <button type="button" class="department-ghost-button" id="cancelPracticeEditModalButton">
                    Отмена
                </button>
                <button type="submit" class="department-primary-button">
                    Сохранить практику
                </button>
            </div>
        </form>
    </div>
</div>

<div class="department-modal-backdrop" id="practiceDetailsModalBackdrop">
    <div class="department-modal department-modal-large department-modal-details">
        <div class="department-modal-header">
            <div>
                <h2 id="practiceDetailsTitle">Сведения о производственной практике</h2>
                <p id="practiceDetailsSubtitle">Полная информация по практике, назначениям и компетенциям.</p>
            </div>
            <button type="button" class="department-modal-close" id="closePracticeDetailsModalButton">?</button>
        </div>

        <div class="department-details-layout">
            <section class="department-details-overview">
                <div class="department-details-overview-main">
                    <div class="department-details-overview-label">Карточка практики</div>
                    <div class="department-details-overview-title" id="practiceDetailsOverviewTitle">
                        Выберите производственную практику
                    </div>
                    <div class="department-details-overview-subtitle" id="practiceDetailsOverviewSubtitle">
                        Здесь будет собрана основная информация, назначения и компетенции.
                    </div>
                </div>

                <div class="department-details-overview-stats" id="practiceDetailsOverviewStats"></div>
            </section>

            <div class="department-details-section">
                <div class="department-details-title">Основная информация</div>
                <div id="practiceDetailsInfo" class="department-details-grid"></div>
            </div>

            <div class="department-details-section">
                <div class="department-details-title">Назначенные студенты</div>
                <div id="practiceDetailsAssignments" class="department-details-list"></div>
            </div>

            <div class="department-details-section">
                <div class="department-details-title">Профессиональные компетенции и виды работ</div>
                <div id="practiceDetailsCompetencies" class="department-details-list"></div>
            </div>
        </div>

        <div class="department-modal-actions">
            <button type="button" class="department-danger-button" id="deletePracticeButton">
                Удалить
            </button>

            <button type="button" class="department-ghost-button" id="openAssignmentsFromDetailsButton">
                Назначение студентов
            </button>

            <button type="button" class="department-secondary-button" id="editPracticeFromDetailsButton">
                Редактировать
            </button>

            <button type="button" class="department-primary-button" id="generateAttestationSheetButton">
                Сформировать аттестационный лист
            </button>
        </div>
    </div>
</div>

<div class="department-modal-backdrop" id="practiceAssignmentsModalBackdrop">
    <div class="department-modal department-modal-assignments">
        <div class="department-modal-header">
            <div>
                <h2 id="practiceAssignmentsModalTitle">Назначение студентов</h2>
                <p id="practiceAssignmentsModalSubtitle">Подберите состав практики и назначьте руководителей по строкам.</p>
            </div>
            <button type="button" class="department-modal-close" id="closePracticeAssignmentsModalButton">?</button>
        </div>

        <div class="student-assignment-shell">
            <div class="field-error field-error-block" data-error-for="StudentAssignments"></div>

            <div class="student-assignment-practice-bar">
                <div class="student-assignment-practice-meta-label">Текущая специальность практики</div>
                <div class="student-assignment-practice-meta" id="assignmentPracticeMeta">
                    Сначала выберите специальность практики
                </div>
            </div>

            <div class="student-assignment-tabs" id="assignmentTabs">
                <button type="button" class="assignment-tab-button active" data-assignment-tab="assigned">
                    <span class="assignment-tab-title">Назначенные студенты</span>
                    <span class="assignment-tab-counter" id="assignedStudentsCounter">0</span>
                </button>

                <button type="button" class="assignment-tab-button" data-assignment-tab="all">
                    <span class="assignment-tab-title">Полный список студентов</span>
                    <span class="assignment-tab-counter" id="allStudentsCounter">0</span>
                </button>
            </div>

            <div class="student-assignment-filters-card">
                <div class="student-assignment-search-wrap">
                    <label class="student-filter-label" for="studentAssignmentSearchInput">Поиск</label>
                    <input type="text"
                           id="studentAssignmentSearchInput"
                           class="form-input department-search-input student-filter-control"
                           placeholder="Поиск по ФИО, специальности или группе..." />
                </div>

                <div class="student-assignment-filter-grid">
                    <div class="student-filter-field">
                        <label class="student-filter-label" for="studentSpecialtyFilterSelect">Специальность</label>
                        <select id="studentSpecialtyFilterSelect" class="native-select-hidden">
                            <option value="">Все специальности</option>
                        </select>
                        <div class="custom-select student-filter-select" data-target="studentSpecialtyFilterSelect">
                            <button type="button" class="custom-select-trigger">Все специальности</button>
                            <div class="custom-select-menu"></div>
                        </div>
                    </div>

                    <div class="student-filter-field">
                        <label class="student-filter-label" for="studentCourseFilterSelect">Курс</label>
                        <select id="studentCourseFilterSelect" class="native-select-hidden">
                            <option value="">Все курсы</option>
                        </select>
                        <div class="custom-select student-filter-select" data-target="studentCourseFilterSelect">
                            <button type="button" class="custom-select-trigger">Все курсы</button>
                            <div class="custom-select-menu"></div>
                        </div>
                    </div>

                    <div class="student-filter-field">
                        <label class="student-filter-label" for="studentGroupFilterSelect">Группа</label>
                        <select id="studentGroupFilterSelect" class="native-select-hidden">
                            <option value="">Все группы</option>
                        </select>
                        <div class="custom-select student-filter-select" data-target="studentGroupFilterSelect">
                            <button type="button" class="custom-select-trigger">Все группы</button>
                            <div class="custom-select-menu"></div>
                        </div>
                    </div>

                    <div class="student-filter-field">
                        <label class="student-filter-label" for="studentSortSelect">Сортировка</label>
                        <select id="studentSortSelect" class="native-select-hidden">
                            <option value="name-asc">ФИО А-Я</option>
                            <option value="name-desc">ФИО Я-А</option>
                            <option value="course-asc">Сначала младшие курсы</option>
                            <option value="course-desc">Сначала старшие курсы</option>
                            <option value="group-asc">Группа А-Я</option>
                            <option value="specialty-asc">Специальность А-Я</option>
                        </select>
                        <div class="custom-select student-filter-select" data-target="studentSortSelect">
                            <button type="button" class="custom-select-trigger">ФИО А-Я</button>
                            <div class="custom-select-menu"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="student-assignment-bulk-bar" id="studentAssignmentBulkBar">
                <label class="student-bulk-checkbox-label">
                    <input type="checkbox" id="assignAllFilteredCheckbox" />
                    <span>Назначить всех найденных</span>
                </label>

                <div class="student-assignment-summary" id="studentAssignmentSummary">
                    Показано студентов: 0
                </div>
            </div>

            <div class="student-assignment-table-panel">
                <div class="student-assignment-table-headline">
                    <div>
                        <div class="student-assignment-table-title">Таблица назначения</div>
                        <div class="student-assignment-table-text">Компактный список с ключевыми данными по каждому студенту.</div>
                    </div>
                </div>

                <div class="student-assignment-table-wrap">
                    <table class="student-assignment-table">
                        <thead>
                            <tr>
                                <th class="student-assignment-col-check">Назначить</th>
                                <th>ФИО студента</th>
                                <th>Специальность</th>
                                <th>Группа</th>
                                <th>Курс</th>
                                <th class="student-assignment-col-supervisor">Руководитель</th>
                            </tr>
                        </thead>
                        <tbody id="studentAssignmentTableBody"></tbody>
                    </table>
                </div>

                <div class="student-assignment-empty-state" id="studentAssignmentEmptyState"></div>
            </div>

            <div class="department-modal-actions">
                <button type="button" class="department-ghost-button" id="cancelPracticeAssignmentsModalButton">
                    Закрыть
                </button>
                <button type="button" class="department-primary-button" id="savePracticeAssignmentsButton">
                    Сохранить назначения
                </button>
            </div>
        </div>
    </div>
</div>

<div class="department-modal-backdrop" id="attestationPreviewModalBackdrop">
    <div class="department-modal department-modal-extra-large">
        <div class="department-modal-header">
            <div>
                <h2>Предпросмотр аттестационного листа</h2>
                <p id="attestationPreviewFileName">Аттестационный лист</p>
            </div>
            <button type="button" class="department-modal-close" id="closeAttestationPreviewModalButton">?</button>
        </div>

        <div class="attestation-preview-container" id="attestationPreviewContainer"></div>

        <div class="department-modal-actions">
            <button type="button" class="department-ghost-button" id="cancelAttestationPreviewButton">
                Отменить
            </button>

            <button type="button" class="department-primary-button" id="downloadAttestationButton">
                Сохранить как...
            </button>
        </div>
    </div>
</div>

<div class="department-modal-backdrop" id="warningModalBackdrop">
    <div class="department-modal department-modal-warning">
        <div class="department-modal-header">
            <div>
                <h2 id="warningModalTitle">Подтверждение действия</h2>
                <p id="warningModalSubtitle">Проверьте последствия перед продолжением.</p>
            </div>
            <button type="button" class="department-modal-close" id="closeWarningModalButton">?</button>
        </div>

        <div class="department-warning-body">
            <div class="department-warning-badge">Внимание</div>
            <div class="department-warning-message" id="warningModalMessage"></div>
            <div class="department-warning-list" id="warningModalConsequences"></div>
        </div>

        <div class="department-modal-actions">
            <button type="button" class="department-secondary-button" id="cancelWarningModalButton">
                Отмена
            </button>
            <button type="button" class="department-primary-button" id="confirmWarningModalButton">
                Продолжить
            </button>
        </div>
    </div>
</div>

<div class="department-modal-backdrop" id="errorModalBackdrop">
    <div class="department-modal department-modal-error">
        <div class="department-modal-header">
            <div>
                <h2 id="errorModalTitle">Не удалось выполнить действие</h2>
                <p id="errorModalSubtitle">Система остановила операцию из-за ошибки.</p>
            </div>
            <button type="button" class="department-modal-close" id="closeErrorModalButton">?</button>
        </div>

        <div class="department-warning-body">
            <div class="department-warning-badge department-warning-badge-error">Ошибка</div>
            <div class="department-warning-message" id="errorModalMessage"></div>
            <div class="department-warning-list" id="errorModalDetails"></div>
        </div>

        <div class="department-modal-actions">
            <button type="button" class="department-primary-button" id="confirmErrorModalButton">
                Понятно
            </button>
        </div>
    </div>
</div>

<template id="competencyItemTemplate">
    <div class="department-repeater-item competency-item">
        <div class="department-repeater-grid">
            <div class="form-group">
                <label class="form-label">Код компетенции</label>
                <input class="form-input competency-code-input" type="text" />
                <div class="field-error competency-code-error"></div>
            </div>

            <div class="form-group">
                <label class="form-label">Количество часов</label>
                <input class="form-input competency-hours-input" type="number" min="1" />
                <div class="field-error competency-hours-error"></div>
            </div>

            <div class="form-group department-form-full">
                <label class="form-label">Описание компетенции</label>
                <textarea class="form-input department-textarea competency-description-input"></textarea>
                <div class="field-error competency-description-error"></div>
            </div>

            <div class="form-group department-form-full">
                <label class="form-label">Виды работ</label>
                <textarea class="form-input department-textarea competency-worktypes-input"></textarea>
                <div class="field-error competency-worktypes-error"></div>
            </div>
        </div>

        <div class="department-repeater-actions">
            <button type="button" class="department-danger-button remove-competency-button">
                Удалить компетенцию
            </button>
        </div>
    </div>
</template>

@await Html.PartialAsync("_ProfileSettingsModal", Model.CurrentUser)

@section Scripts {
    <script>
        window.departmentStaffInitialPractices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Practices));
    </script>
    <script src="~/js/student-profile.js"></script>
    <script src="~/js/departmentStaff.js"></script>
}





