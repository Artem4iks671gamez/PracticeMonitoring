@model PracticeMonitoring.Web.Models.Notifications.NotificationsPanelViewModel?
@using System.Collections.Generic

@{
    var notifications = Model?.Items ?? new List<PracticeMonitoring.Web.Models.Notifications.NotificationItemViewModel>();
    var unreadCount = notifications.Count(x => !x.IsRead);
}

<div class="notifications-panel-card">
    <div class="notifications-panel-header">
        <div>
            <div class="messaging-eyebrow">Уведомления</div>
            <h3>Центр событий</h3>
            <p>Назначения практик, изменения руководителей и важные действия по вашим данным.</p>
        </div>

        @if (unreadCount > 0)
        {
            <form asp-controller="Notifications" asp-action="MarkAllAsRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="notifications-read-all-button">Прочитать все</button>
            </form>
        }
    </div>

    @if (notifications.Count == 0)
    {
        <div class="notifications-empty-state">
            <div class="notifications-empty-icon">i</div>
            <div>
                <strong>Пока нет уведомлений</strong>
                <span>Здесь появятся назначения практик, напоминания и системные события.</span>
            </div>
        </div>
    }
    else
    {
        <div class="notifications-list">
            @foreach (var notification in notifications)
            {
                <article class="notification-item @(notification.IsRead ? "is-read" : "is-unread")">
                    <div class="notification-item-main">
                        <div class="notification-title-row">
                            <h4>@notification.Title</h4>
                            @if (!notification.IsRead)
                            {
                                <span class="notification-unread-dot"></span>
                            }
                        </div>
                        <p>@notification.Message</p>
                        <div class="notification-meta">
                            <span>@notification.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                            <span>@notification.Category</span>
                        </div>
                    </div>

                    <div class="notification-actions">
                        @if (!string.IsNullOrWhiteSpace(notification.LinkUrl))
                        {
                            <a class="notifications-link-button" href="@notification.LinkUrl">Перейти</a>
                        }

                        @if (!notification.IsRead)
                        {
                            <form asp-controller="Notifications" asp-action="MarkAsRead" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button type="submit" class="notifications-muted-button">Прочитано</button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>

