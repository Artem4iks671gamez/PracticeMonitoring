@using System.Text.Json
@model PracticeMonitoring.Web.Models.Student.StudentPageViewModel

@{
    ViewData["Title"] = "Кабинет студента";

    var user = Model.CurrentUser;
    var groupText = !string.IsNullOrWhiteSpace(user.GroupName)
        ? $"Студент группы {user.GroupName}"
        : "Студент";

    var specialtyText = !string.IsNullOrWhiteSpace(user.SpecialtyCode) || !string.IsNullOrWhiteSpace(user.SpecialtyName)
        ? $"{user.SpecialtyCode} {user.SpecialtyName}".Trim()
        : "Специальность пока не указана";

    var avatarInitials =
        $"{(string.IsNullOrWhiteSpace(user.Surname) ? "" : user.Surname[0])}{(string.IsNullOrWhiteSpace(user.FirstName) ? "" : user.FirstName[0])}";

    var activePracticesCount = Model.Practices.Count(x => !x.IsCompleted);
    var completedPracticesCount = Model.Practices.Count(x => x.IsCompleted);
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
}

<div class="student-shell"
     data-student-workspace
     data-get-practice-url="@Url.Action("GetPractice", "Student")"
     data-save-organization-url="@Url.Action("SaveOrganization", "Student")"
     data-save-diary-url="@Url.Action("SaveDiaryEntry", "Student")"
     data-save-report-items-url="@Url.Action("SaveReportItems", "Student")"
     data-save-sources-url="@Url.Action("SaveSources", "Student")"
     data-upload-appendix-url="@Url.Action("UploadAppendix", "Student")"
     data-upload-diary-attachment-url="@Url.Action("UploadDiaryAttachment", "Student")"
     data-delete-appendix-url="@Url.Action("DeleteAppendix", "Student")"
     data-download-appendix-url="@Url.Action("DownloadAppendix", "Student")"
     data-download-diary-attachment-url="@Url.Action("DownloadDiaryAttachment", "Student")"
     data-download-practice-report-url="@Url.Action("DownloadPracticeReport", "Student")">
    <section class="student-hero-card">
        <div class="student-identity">
            <div class="student-avatar student-avatar-compact" id="studentAvatarPreview">
                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                {
                    <img src="@user.AvatarUrl" alt="Аватар студента" />
                }
                else
                {
                    <span>@avatarInitials</span>
                }
            </div>

            <div class="student-identity-text">
                <div class="student-role-line">@groupText</div>
                <h1 class="student-fullname" id="headerFullName">@user.FullName</h1>
                <div class="student-specialty-line">@specialtyText</div>
                <div class="student-email-line" id="headerEmail">@user.Email</div>
            </div>
        </div>

        <div class="student-actions">
            <button type="button" class="student-primary-button" id="openProfileSettingsButton">
                Профиль
            </button>
        </div>
    </section>

    @if (TempData["ProfileSuccess"] is string successMessage)
    {
        <div class="student-alert student-alert-success">@successMessage</div>
    }

    @if (TempData["ProfileError"] is string errorMessage)
    {
        <div class="student-alert student-alert-error">@errorMessage</div>
    }

    <div class="student-workspace">
        <aside class="student-sidebar-card">
            <div class="student-sidebar-block">
                <div class="student-sidebar-title">Навигация</div>

                <div class="student-sidebar-nav">
                    <button type="button" class="student-nav-button active" data-student-panel-target="studentPracticesPanel">
                        Практики
                    </button>

                    <button type="button" class="student-nav-button nav-button-with-badge" data-student-panel-target="studentChatsPanel">
                        <span>Чаты</span>
                        @if (Model.UnreadChatsCount > 0)
                        {
                            <span class="nav-unread-badge">@Model.UnreadChatsCount</span>
                        }
                    </button>

                    <button type="button" class="student-nav-button nav-button-with-badge" data-student-panel-target="studentNotificationsPanel">
                        <span>Уведомления</span>
                        @if (Model.Notifications.UnreadCount > 0)
                        {
                            <span class="nav-unread-badge">@Model.Notifications.UnreadCount</span>
                        }
                    </button>
                </div>
            </div>

            <div class="student-sidebar-divider"></div>

            <div class="student-sidebar-block">
                <div class="student-sidebar-title">Действия</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="student-secondary-button student-full-button">Выйти</button>
                </form>
            </div>
        </aside>

        <section class="student-main-card">
            <div class="student-panel active" id="studentPracticesPanel" data-student-panel>
                <div class="student-panel-header">
                    <div>
                        <h2>Мои производственные практики</h2>
                        <p>Сведения, организация, дневник, источники и приложения по каждой назначенной практике.</p>
                    </div>
                </div>

                <div class="student-practice-tabs">
                    <button type="button" class="student-subtab-button active" data-practice-status="active">
                        Активные практики
                        <span>@activePracticesCount</span>
                    </button>
                    <button type="button" class="student-subtab-button" data-practice-status="completed">
                        Завершённые практики
                        <span>@completedPracticesCount</span>
                    </button>
                </div>

                <div class="student-practice-toolbar">
                    <input type="text" class="form-input student-practice-search" id="studentPracticeSearch" placeholder="Поиск по названию, индексу, ПМ, руководителю или организации..." />
                    <select class="form-input student-practice-sort" id="studentPracticeSort">
                        <option value="date-asc">Сначала ранние сроки</option>
                        <option value="date-desc">Сначала поздние сроки</option>
                        <option value="name-asc">Название А-Я</option>
                        <option value="progress-asc">Сначала незаполненные</option>
                    </select>
                </div>

                <div class="student-practice-summary" id="studentPracticesSummary">
                    Назначено практик: @Model.Practices.Count
                </div>

                <div class="student-practice-table" id="studentPracticesTable">
                    <div class="student-practice-table-head">
                        <span>Практика</span>
                        <span>Сроки</span>
                        <span>Руководитель</span>
                        <span>Заполнение</span>
                        <span></span>
                    </div>

                    <div class="student-practice-table-body" id="studentPracticesList">
                        @if (Model.Practices.Count == 0)
                        {
                            <div class="student-empty-state">
                                Пока нет назначенных производственных практик. После назначения работником отдела здесь появятся сроки, руководитель и действия по заполнению.
                            </div>
                        }
                        else
                        {
                            @foreach (var practice in Model.Practices)
                            {
                                var progressText = $"{practice.DiaryEntriesCount}/{practice.WorkDaysCount} дней";
                                <article class="student-practice-row"
                                         data-assignment-id="@practice.AssignmentId"
                                         data-status="@(practice.IsCompleted ? "completed" : "active")"
                                         data-search="@($"{practice.PracticeIndex} {practice.Name} {practice.ProfessionalModuleCode} {practice.ProfessionalModuleName} {practice.SupervisorFullName} {practice.OrganizationName}".ToLowerInvariant())"
                                         data-name="@practice.Name"
                                         data-start-date="@practice.StartDate.ToString("yyyy-MM-dd")"
                                         data-progress-ready="@practice.HasRequiredDetails.ToString().ToLower()">
                                    <div class="student-practice-title-cell">
                                        <div class="student-practice-chip-row">
                                            <span class="student-practice-index">@practice.PracticeIndex</span>
                                            <span class="student-practice-state @(practice.IsCompleted ? "completed" : "active")">@(practice.IsCompleted ? "Завершена" : "Активна")</span>
                                            @if (practice.IsDetailsOverdue)
                                            {
                                                <span class="student-practice-state warning">Просрочены сведения</span>
                                            }
                                        </div>
                                        <strong>@practice.Name</strong>
                                        <small>@practice.ProfessionalModuleCode @practice.ProfessionalModuleName</small>
                                    </div>

                                    <div class="student-practice-date-cell">
                                        <strong>@practice.StartDate.ToString("dd.MM.yyyy") - @practice.EndDate.ToString("dd.MM.yyyy")</strong>
                                        <small>@practice.Hours ч. · до @practice.DetailsDueDate.ToString("dd.MM.yyyy") заполнить организацию</small>
                                    </div>

                                    <div class="student-practice-supervisor-cell">
                                        <strong>@(practice.SupervisorFullName ?? "Не назначен")</strong>
                                        <small>@(practice.OrganizationName ?? "Организация не указана")</small>
                                    </div>

                                    <div class="student-practice-progress-cell">
                                        <strong>@(practice.HasRequiredDetails ? "Сведения заполнены" : "Нужно заполнить")</strong>
                                        <small>Дневник: @progressText</small>
                                    </div>

                                    <div class="student-practice-action-cell">
                                        <button type="button" class="student-primary-button student-open-practice-button" data-open-practice="@practice.AssignmentId">
                                            Открыть
                                        </button>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="student-panel" id="studentChatsPanel" data-student-panel>
                @await Html.PartialAsync("_MessagingWorkspace", Model.Messaging)
            </div>

            <div class="student-panel" id="studentNotificationsPanel" data-student-panel>
                @await Html.PartialAsync("_NotificationsPanel", Model.Notifications)
            </div>
        </section>
    </div>

    <div class="student-modal-backdrop" id="studentPracticeModal" hidden>
        <div class="student-practice-modal">
            <div class="student-modal-header">
                <div>
                    <div class="student-modal-eyebrow" id="studentPracticeModalEyebrow">Производственная практика</div>
                    <h2 id="studentPracticeModalTitle">Практика</h2>
                    <p id="studentPracticeModalSubtitle"></p>
                </div>
                <button type="button" class="student-modal-close" id="closeStudentPracticeModal">×</button>
            </div>

            <div class="student-modal-status" id="studentPracticeModalStatus" hidden></div>

            <div class="student-modal-tabs">
                <button type="button" class="student-modal-tab active" data-student-modal-tab="overview">Сведения</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="organization">Организация</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="diary">Дневник</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="introduction">Введение</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="technical">Технические средства</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="software">Программные средства</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="sources">Источники</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="appendices">Приложения</button>
                <button type="button" class="student-modal-tab" data-student-modal-tab="documents">Формирование документов</button>
            </div>

            <div class="student-modal-body">
                <section class="student-modal-panel active" data-student-modal-panel="overview">
                    <div class="student-overview-grid" id="studentPracticeOverview"></div>
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Профессиональные компетенции и виды работ</h3>
                        </div>
                        <div class="student-competency-list" id="studentPracticeCompetencies"></div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="organization">
                    <div class="student-section-card student-organization-view" id="studentOrganizationView">
                        <div class="student-section-header">
                            <div>
                                <h3>Сведения об организации</h3>
                                <span>После сохранения данные отображаются как карточка. Для изменений нажмите “Редактировать”.</span>
                            </div>
                            <button type="button" class="student-primary-button" id="editOrganizationButton">Редактировать</button>
                        </div>
                        <div class="student-readonly-grid" id="studentOrganizationReadonly"></div>
                    </div>

                    <form id="studentOrganizationForm" class="student-form-grid" hidden novalidate>
                        <div class="form-group student-form-wide">
                            <label class="form-label" for="organizationFullName">Полное название организации</label>
                            <input class="form-input" id="organizationFullName" name="organizationFullName" maxlength="500" placeholder="Например: Общество с ограниченной ответственностью «Информационные системы»" />
                            <div class="student-field-error" data-field-error="OrganizationFullName"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationShortName">Сокращенное название</label>
                            <input class="form-input" id="organizationShortName" name="organizationShortName" maxlength="300" placeholder="ООО «Информационные системы»" />
                            <div class="student-field-error" data-field-error="OrganizationShortName"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationAddress">Адрес организации</label>
                            <input class="form-input" id="organizationAddress" name="organizationAddress" maxlength="500" />
                            <div class="student-field-error" data-field-error="OrganizationAddress"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationSupervisorFullName">ФИО руководителя от организации</label>
                            <input class="form-input" id="organizationSupervisorFullName" name="organizationSupervisorFullName" maxlength="200" />
                            <div class="student-field-error" data-field-error="OrganizationSupervisorFullName"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationSupervisorPosition">Должность</label>
                            <input class="form-input" id="organizationSupervisorPosition" name="organizationSupervisorPosition" maxlength="200" />
                            <div class="student-field-error" data-field-error="OrganizationSupervisorPosition"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationSupervisorPhone">Телефон</label>
                            <input class="form-input" id="organizationSupervisorPhone" name="organizationSupervisorPhone" inputmode="tel" maxlength="18" placeholder="+7 (___) ___-__-__" />
                            <div class="student-field-error" data-field-error="OrganizationSupervisorPhone"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="organizationSupervisorEmail">Почта</label>
                            <input class="form-input" id="organizationSupervisorEmail" name="organizationSupervisorEmail" type="text" maxlength="200" placeholder="mail@example.ru" />
                            <div class="student-field-error" data-field-error="OrganizationSupervisorEmail"></div>
                        </div>
                        <div class="form-group student-form-wide">
                            <label class="form-label" for="practiceTaskContent">Содержание задания на практику</label>
                            <textarea class="form-input student-textarea" id="practiceTaskContent" name="practiceTaskContent" rows="5" maxlength="4000"></textarea>
                            <div class="student-field-error" data-field-error="PracticeTaskContent"></div>
                        </div>
                        <div class="student-form-actions student-form-wide">
                            <button type="button" class="student-secondary-button" id="cancelOrganizationEditButton">Отмена</button>
                            <button type="submit" class="student-primary-button">Сохранить сведения</button>
                        </div>
                    </form>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="diary">
                    <div class="student-diary-workspace">
                        <aside class="student-section-card student-calendar-card">
                            <div class="student-section-header">
                                <h3>Календарь практики</h3>
                                <span id="diaryProgressLabel"></span>
                            </div>
                            <div class="student-calendar" id="studentDiaryCalendar"></div>
                        </aside>

                        <form id="studentDiaryForm" class="student-section-card student-diary-editor">
                            <div class="student-report-global-fields">
                                <div class="form-group">
                                    <label class="form-label" for="studentDuties">Выполняемые обязанности</label>
                                    <textarea class="form-input student-textarea" id="studentDuties" name="studentDuties" rows="3" maxlength="4000" placeholder="В ходе прохождения практики я выполнял/а следующие обязанности:"></textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="providedMaterialsDescription">Описание предоставленных материалов</label>
                                    <textarea class="form-input student-textarea" id="providedMaterialsDescription" name="providedMaterialsDescription" rows="3" maxlength="4000" placeholder="Для выполнения заданий были предоставлены"></textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="workScheduleDescription">Описание графика работы</label>
                                    <textarea class="form-input student-textarea" id="workScheduleDescription" name="workScheduleDescription" rows="3" maxlength="4000"></textarea>
                                </div>
                                <div class="student-form-actions">
                                    <button type="button" class="student-secondary-button" id="savePracticeContentButton">Сохранить данные отчёта</button>
                                </div>
                            </div>
                            <input id="diaryWorkDate" name="workDate" type="hidden" />
                            <div class="student-section-header">
                                <div>
                                    <h3 id="diaryEditorTitle">Рабочий день</h3>
                                    <span>Выберите дату слева, затем заполните дневник и подробный отчёт.</span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="diaryShortDescription">Краткое описание для дневника</label>
                                <textarea class="form-input student-textarea student-short-textarea" id="diaryShortDescription" name="shortDescription" rows="3" maxlength="1000"></textarea>
                                <div class="student-field-error" data-field-error="ShortDescription"></div>
                            </div>
                            <div class="student-report-summary-card" id="studentReportSummaryCard">
                                <div>
                                    <span class="student-report-summary-label">Подробный отчёт за день</span>
                                    <h4>Отдельный документ для итогового отчёта</h4>
                                    <p id="studentReportPreviewExcerpt">Отчёт пока пустой. Откройте редактор и добавьте текст, таблицу или рисунок.</p>
                                    <div class="student-report-summary-meta">
                                        <span id="studentReportPreviewStats">0 текстовых блоков · 0 таблиц · 0 рисунков</span>
                                        <span id="studentReportPreviewUpdated">Не сохранялся</span>
                                    </div>
                                </div>
                                <button type="button" class="student-primary-button" id="openDayReportEditorButton">Редактировать отчёт</button>
                            </div>
                            <input type="hidden" id="diaryDetailedReport" name="detailedReport" />
                            <div class="student-field-error" data-field-error="DetailedReport"></div>
                            <button type="submit" class="student-primary-button">Сохранить день</button>
                        </form>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="introduction">
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Введение</h3>
                            <span>Цель, виды работ, программные средства и технологии для итогового отчёта</span>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="introductionMainGoal">Описание основной цели</label>
                            <textarea class="form-input student-textarea" id="introductionMainGoal" name="introductionMainGoal" rows="4" maxlength="4000" placeholder="Основной целью практики являлась"></textarea>
                        </div>
                        <div class="student-report-tables" id="studentIntroductionTables"></div>
                        <div class="student-form-actions">
                            <button type="button" class="student-primary-button" id="saveIntroductionButton">Сохранить введение</button>
                        </div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="technical">
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Технические средства</h3>
                            <span>Тип оборудования, наименование и характеристики</span>
                        </div>
                        <div class="student-report-tables" id="studentTechnicalTools"></div>
                        <div class="student-form-actions">
                            <button type="button" class="student-primary-button" id="saveTechnicalToolsButton">Сохранить технические средства</button>
                        </div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="software">
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Программные средства</h3>
                            <span>Тип средства, название и назначение</span>
                        </div>
                        <div class="student-report-tables" id="studentSoftwareTools"></div>
                        <div class="student-form-actions">
                            <button type="button" class="student-primary-button" id="saveSoftwareToolsButton">Сохранить программные средства</button>
                        </div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="sources">
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Список использованных источников</h3>
                            <button type="button" class="student-secondary-button" id="addSourceButton">Добавить источник</button>
                        </div>
                        <div class="student-source-list" id="studentSourcesList"></div>
                        <div class="student-form-actions">
                            <button type="button" class="student-primary-button" id="saveSourcesButton">Сохранить источники</button>
                        </div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="appendices">
                    <div class="student-diary-layout">
                        <form id="studentAppendixForm" class="student-section-card" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="student-section-header">
                                <h3>Новое приложение</h3>
                                <span>Например: Приложение А. Код программы</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="appendixTitle">Название приложения</label>
                                <input class="form-input" id="appendixTitle" name="title" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="appendixDescription">Описание</label>
                                <textarea class="form-input student-textarea" id="appendixDescription" name="description" rows="4"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="appendixFile">Файл</label>
                                <input id="appendixFile" name="file" type="file" accept=".doc,.docx,.pdf,.zip,.rar,.7z,.txt,.cs,.sql,.png,.jpg,.jpeg" hidden />
                                <label for="appendixFile" class="student-file-dropzone" id="appendixFileDropzone">
                                    <strong>Выберите файл приложения</strong>
                                    <span>DOCX, PDF, архив, код или изображение до 15 МБ</span>
                                    <small id="appendixFileName">Файл не выбран</small>
                                </label>
                                <div class="student-field-error" data-field-error="AppendixFile"></div>
                            </div>
                            <button type="submit" class="student-primary-button">Загрузить приложение</button>
                        </form>
                        <div class="student-section-card">
                            <div class="student-section-header">
                                <h3>Загруженные приложения</h3>
                            </div>
                            <div class="student-appendix-list" id="studentAppendicesList"></div>
                        </div>
                    </div>
                </section>

                <section class="student-modal-panel" data-student-modal-panel="documents">
                    <div class="student-section-card">
                        <div class="student-section-header">
                            <h3>Формирование документов</h3>
                            <span>Отчёт формируется автоматически по шаблону DOCX.</span>
                        </div>
                        <div class="student-document-actions">
                            <button type="button" class="student-secondary-button" disabled>Сформировать аттестационный лист</button>
                            <button type="button" class="student-secondary-button" disabled>Сформировать дневник практики</button>
                            <button type="button" class="student-primary-button" id="downloadPracticeReportButton">Сформировать отчёт практики</button>
                        </div>
                        <div class="student-document-errors" id="studentDocumentErrors" hidden></div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <div class="student-report-workspace-backdrop" id="studentReportEditorModal" hidden>
        <div class="student-report-workspace" role="dialog" aria-modal="true" aria-labelledby="studentReportEditorTitle">
            <header class="student-report-workspace-header">
                <div>
                    <span class="student-report-workspace-eyebrow">Редактор подробного отчёта</span>
                    <h2 id="studentReportEditorTitle">Рабочий день</h2>
                    <p>Краткое описание для дневника сюда не попадает. Здесь формируется документная часть для итогового отчёта.</p>
                </div>
                <div class="student-report-workspace-actions">
                    <span class="student-report-save-state saved" id="studentReportSaveState">Сохранено</span>
                    <button type="button" class="student-secondary-button" id="closeDayReportEditorButton">Закрыть</button>
                    <button type="button" class="student-primary-button" id="saveDayReportEditorButton">Сохранить</button>
                </div>
            </header>

            <div class="student-report-toolbar" id="studentReportToolbar">
                <span class="student-report-toolbar-label">Добавить содержимое</span>
                <button type="button" data-report-insert="text">+ Текст</button>
                <button type="button" data-report-insert="table">+ Таблица</button>
                <button type="button" data-report-insert="image">+ Рисунок</button>
            </div>
            <div class="student-report-validation-summary" id="studentReportValidationSummary" hidden></div>

            <div class="student-report-workspace-grid">
                <aside class="student-report-side-panel">
                    <h3>Структура дня</h3>
                    <div id="studentReportOutline" class="student-report-outline"></div>
                    <div class="student-report-side-hint">
                        Выберите блок на листе, чтобы переместить, удалить или вставить новый блок после него.
                    </div>
                </aside>

                <main class="student-report-document-area">
                    <div class="student-report-a4-page" id="studentReportDocumentCanvas">
                        <div class="student-report-empty-state">
                            <strong>Отчёт пока пустой</strong>
                            <span>Добавьте текст, таблицу или рисунок через панель сверху.</span>
                        </div>
                    </div>
                </main>

                <aside class="student-report-properties-panel">
                    <h3>Свойства блока</h3>
                    <div id="studentReportProperties">
                        <p>Выберите блок на листе.</p>
                    </div>
                </aside>
            </div>

            <input type="file" id="studentReportImageInput" accept="image/png,image/jpeg,image/webp" hidden />
            <div class="student-table-context-menu" id="studentTableContextMenu" hidden></div>
            <div class="student-report-close-guard" id="studentReportCloseGuard" hidden>
                <div>
                    <strong>Есть несохранённые изменения</strong>
                    <span>Если закрыть редактор сейчас, последние правки подробного отчёта за день будут потеряны.</span>
                </div>
                <button type="button" class="student-secondary-button" id="cancelReportCloseButton">Остаться</button>
                <button type="button" class="student-primary-button" id="discardReportChangesButton">Закрыть без сохранения</button>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_ProfileSettingsModal", user)

@section Scripts {
    <script>
        window.initialStudentPractices = @Html.Raw(JsonSerializer.Serialize(Model.Practices, jsonOptions));
    </script>
    <script src="~/js/student-profile.js"></script>
    <script src="~/js/student.js"></script>
}
