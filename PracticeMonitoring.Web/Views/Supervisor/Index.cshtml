@model PracticeMonitoring.Web.Models.Supervisor.SupervisorPageViewModel

@{
    ViewData["Title"] = "Руководитель практики";

    var user = Model.CurrentUser;
    var avatarInitials =
        $"{(string.IsNullOrWhiteSpace(user.Surname) ? "" : user.Surname[0])}{(string.IsNullOrWhiteSpace(user.FirstName) ? "" : user.FirstName[0])}";
}

<div class="student-shell">
    <section class="student-topbar">
        <div class="student-identity">
            <div class="student-identity-text">
                <div class="student-role-line">Руководитель практики</div>
                <h1 class="student-fullname">@user.FullName</h1>
                <div class="student-specialty-line">Общение со студентами, отделом и администрацией</div>
                <div class="student-email-line">@user.Email</div>
            </div>

            <div class="student-avatar-block">
                <div class="student-avatar">
                    @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                    {
                        <img src="@user.AvatarUrl" alt="Аватар руководителя" />
                    }
                    else
                    {
                        <span>@avatarInitials</span>
                    }
                </div>
            </div>
        </div>

        <div class="student-actions">
            <button type="button" class="student-secondary-button" id="openProfileSettingsButton">
                Настройки профиля
            </button>

            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="student-danger-button">
                    Выйти
                </button>
            </form>
        </div>
    </section>

    @if (TempData["ProfileSuccess"] is string successMessage)
    {
        <div class="student-alert student-alert-success">@successMessage</div>
    }

    @if (TempData["ProfileError"] is string errorMessage)
    {
        <div class="student-alert student-alert-error">@errorMessage</div>
    }

    <div class="role-page-tabs">
        <button type="button" class="role-page-nav-button active" data-page-panel-target="supervisorOverviewPanel">
            Обзор
        </button>
        <button type="button" class="role-page-nav-button" data-page-panel-target="supervisorChatsPanel">
            Чаты
        </button>
        <button type="button" class="role-page-nav-button" data-page-panel-target="supervisorNotificationsPanel">
            Уведомления
        </button>
    </div>

    <div class="role-page-panel active" id="supervisorOverviewPanel" data-page-panel>
        <section class="student-dashboard">
            <div class="dashboard-card dashboard-card-wide">
                <div class="dashboard-card-header">
                    <h2>Рабочее место руководителя</h2>
                    <span>Supervisor</span>
                </div>
                <p>
                    Основной канал взаимодействия с назначенными студентами, работниками отдела и администраторами вынесен во вкладку `Чаты`.
                </p>
            </div>

            <div class="dashboard-grid">
                <div class="dashboard-card">
                    <div class="dashboard-card-header">
                        <h3>Профиль</h3>
                    </div>
                    <ul class="dashboard-list">
                        <li><strong>ФИО:</strong> @user.FullName</li>
                        <li><strong>Email:</strong> @user.Email</li>
                        <li><strong>Роль:</strong> Руководитель практики</li>
                        <li><strong>Тема:</strong> @(user.Theme == "dark" ? "Тёмная" : "Светлая")</li>
                    </ul>
                </div>

                <div class="dashboard-card">
                    <div class="dashboard-card-header">
                        <h3>Коммуникации</h3>
                    </div>
                    <p class="dashboard-empty">
                        Вы можете инициировать диалоги со всеми ролями системы, а также принимать сообщения и файлы от студентов.
                    </p>
                </div>
            </div>
        </section>
    </div>

    <div class="role-page-panel" id="supervisorChatsPanel" data-page-panel>
        @await Html.PartialAsync("_MessagingWorkspace", Model.Messaging)
    </div>

    <div class="role-page-panel" id="supervisorNotificationsPanel" data-page-panel>
        @await Html.PartialAsync("_NotificationsPanel")
    </div>
</div>

@await Html.PartialAsync("_ProfileSettingsModal", user)

@section Scripts {
    <script src="~/js/student-profile.js"></script>
}

