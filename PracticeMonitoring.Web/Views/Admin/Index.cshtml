@model PracticeMonitoring.Web.Models.Admin.AdminUsersPageViewModel

@{
    ViewData["Title"] = "Админ-панель";
}

<div class="admin-shell">
    <section class="admin-hero-card">
        <div>
            <div class="admin-badge">Панель администратора</div>
            <h1 class="admin-title">Управление системой</h1>
            <p class="admin-subtitle">Администратор: @Model.AdminFullName</p>
        </div>

        <div class="admin-hero-actions">
            <button type="button" class="admin-secondary-button" id="openProfileSettingsButton">
                Профиль
            </button>

            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="admin-danger-button">Выйти</button>
            </form>
        </div>
    </section>

    @if (TempData["AdminSuccess"] is string successMessage)
    {
        <div class="student-alert student-alert-success">@successMessage</div>
    }

    @if (TempData["AdminError"] is string errorMessage)
    {
        <div class="student-alert student-alert-error">@errorMessage</div>
    }

    @if (TempData["ProfileSuccess"] is string profileSuccess)
    {
        <div class="student-alert student-alert-success">@profileSuccess</div>
    }

    @if (TempData["ProfileError"] is string profileError)
    {
        <div class="student-alert student-alert-error">@profileError</div>
    }

    <section class="admin-workspace">
        <aside class="admin-sidebar-card">
            <div class="admin-sidebar-block">
                <div class="admin-sidebar-title">Навигация</div>

                <div class="admin-sidebar-nav">
                    <button type="button" class="admin-nav-button active" data-panel="accounts-panel">
                        Аккаунты
                    </button>

                    <button type="button" class="admin-nav-button" data-panel="logs-panel">
                        Журнал
                    </button>

                    <button type="button" class="admin-nav-button" data-panel="chats-panel">
                        Чаты
                    </button>

                    <button type="button" class="admin-nav-button" data-panel="notifications-panel">
                        Уведомления
                    </button>
                </div>
            </div>

            <div class="admin-sidebar-divider"></div>

            <div class="admin-sidebar-block">
                <div class="admin-sidebar-title">Быстрые действия</div>

                <div class="admin-sidebar-actions">
                    <button type="button" class="admin-primary-button admin-action-button" data-create-role="Admin">
                        Создать администратора
                    </button>

                    <button type="button" class="admin-primary-button admin-action-button" data-create-role="Supervisor">
                        Создать руководителя практики
                    </button>

                    <button type="button" class="admin-primary-button admin-action-button" data-create-role="DepartmentStaff">
                        Создать работника отдела
                    </button>
                </div>
            </div>

            <div class="admin-sidebar-divider"></div>

            <div class="admin-sidebar-block">
                <div class="admin-sidebar-title">Резервная копия базы</div>

                <div class="admin-sidebar-actions">
                    <form asp-controller="Admin" asp-action="BackupDatabase" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="admin-primary-button admin-full-button">
                            Сохранить копию БД
                        </button>
                    </form>

                    <form asp-controller="Admin" asp-action="RestoreDatabase" method="post" enctype="multipart/form-data" id="restoreDatabaseForm">
                        @Html.AntiForgeryToken()

                        <div class="file-upload-control file-upload-control-column" style="margin-bottom: 13px">
                            <input type="file" id="restoreBackupFile" name="backupFile" accept=".dump" class="file-upload-input" />
                            <label for="restoreBackupFile" class="file-upload-button">Выбрать backup-файл</label>
                            <span class="file-upload-name" id="restoreBackupFileName">Файл не выбран</span>
                        </div>

                        <button type="submit" class="admin-danger-button admin-full-button">
                            Загрузить БД
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <section class="admin-main-card">
            <div class="admin-panel active" id="accounts-panel">
                <div class="admin-panel-header">
                    <div>
                        <h2>Аккаунты пользователей</h2>
                        <p>Компактный список с фильтрацией, поиском и сортировкой.</p>
                    </div>
                </div>

                <div class="accounts-toolbar">
                    <div class="accounts-toolbar-row">
                        <div class="accounts-search-wrap">
                            <input type="text"
                                   id="accountsSearchInput"
                                   class="form-input accounts-search-input"
                                   placeholder="Поиск по ФИО, email, группе или специальности..." />
                        </div>

                        <div class="accounts-sort-wrap">
                            <select id="sortSelect" class="native-select-hidden">
                                <option value="name-asc">ФИО А-Я</option>
                                <option value="name-desc">ФИО Я-А</option>
                                <option value="role-asc">Роль А-Я</option>
                                <option value="status-desc">Активные выше</option>
                            </select>

                            <div class="custom-select custom-sort-select" data-target="sortSelect">
                                <button type="button" class="custom-select-trigger">ФИО А-Я</button>
                                <div class="custom-select-menu"></div>
                            </div>
                        </div>
                    </div>

                    <div class="accounts-filters-panel">
                        <div class="filter-section">
                            <div class="filter-section-title">Роли</div>
                            <div class="role-filter-list" id="roleFilterGroup">
                                <label class="role-check">
                                    <input type="checkbox" data-role-filter="Admin" checked />
                                    <span class="role-check-indicator"></span>
                                    <span class="role-check-text">Администратор</span>
                                </label>

                                <label class="role-check">
                                    <input type="checkbox" data-role-filter="Student" checked />
                                    <span class="role-check-indicator"></span>
                                    <span class="role-check-text">Студент</span>
                                </label>

                                <label class="role-check">
                                    <input type="checkbox" data-role-filter="Supervisor" checked />
                                    <span class="role-check-indicator"></span>
                                    <span class="role-check-text">Руководитель практики</span>
                                </label>

                                <label class="role-check">
                                    <input type="checkbox" data-role-filter="DepartmentStaff" checked />
                                    <span class="role-check-indicator"></span>
                                    <span class="role-check-text">Работник отдела</span>
                                </label>
                            </div>
                        </div>

                        <div class="filter-section">
                            <div class="filter-section-title">Статус</div>
                            <div class="status-toggle-group" id="statusFilterGroup">
                                <label class="switch-filter">
                                    <input type="checkbox" data-status-filter="active" checked />
                                    <span class="switch-slider"></span>
                                    <span class="switch-label">Активные</span>
                                </label>

                                <label class="switch-filter">
                                    <input type="checkbox" data-status-filter="inactive" checked />
                                    <span class="switch-slider"></span>
                                    <span class="switch-label">Неактивные</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="accounts-summary-bar">
                    <span id="accountsCountLabel">Показано аккаунтов: @Model.Users.Count</span>
                </div>

                <div class="accounts-scroll-list" id="accountsList">
                    @foreach (var user in Model.Users)
                    {
                        var avatarInitials = string.Join("", user.FullName
                        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                        .Take(2)
                        .Select(x => x[0]))
                        .ToUpper();

                        var specialtyText = string.IsNullOrWhiteSpace(user.SpecialtyCode)
                        ? "Специальность не указана"
                        : $"{user.SpecialtyCode} {user.SpecialtyName}".Trim();

                        var roleDescription = user.Role switch
                        {
                            "Supervisor" => "Руководитель практики от техникума",
                            "DepartmentStaff" => "Работник отдела производственного обучения",
                            "Admin" => "Администратор системы",
                            _ => string.Empty
                        };

                        <article class="account-card"
                                 data-user-id="@user.Id"
                                 data-full-name="@user.FullName"
                                 data-email="@user.Email"
                                 data-role="@user.Role"
                                 data-active="@user.IsActive.ToString().ToLower()"
                                 data-avatar-url="@user.AvatarUrl"
                                 data-group-id="@user.GroupId"
                                 data-group-name="@user.GroupName"
                                 data-course="@user.Course"
                                 data-specialty-id="@user.SpecialtyId"
                                 data-specialty-code="@user.SpecialtyCode"
                                 data-specialty-name="@user.SpecialtyName">
                            <div class="account-card-avatar">
                                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                                {
                                    <img src="@user.AvatarUrl" alt="Аватар пользователя" />
                                }
                                else
                                {
                                    <span>@avatarInitials</span>
                                }
                            </div>

                            <div class="account-card-main">
                                <div class="account-card-topline">
                                    <div class="account-card-name-block">
                                        <h3 class="account-card-name">@user.FullName</h3>
                                        <div class="account-card-email">@user.Email</div>
                                    </div>

                                    <div class="account-card-badges">
                                        <span class="account-role-chip">@user.Role</span>
                                        <span class="account-status @(user.IsActive ? "account-status-active" : "account-status-inactive")">
                                            @(user.IsActive ? "Активен" : "Неактивен")
                                        </span>
                                    </div>
                                </div>

                                <div class="account-card-meta-row">
                                    @if (user.Role == "Student")
                                    {
                                        <div class="account-inline-info">
                                            <span class="account-inline-label">Специальность:</span>
                                            <span class="account-inline-value">@specialtyText</span>
                                        </div>

                                        <div class="account-inline-separator"></div>

                                        <div class="account-inline-info">
                                            <span class="account-inline-label">Группа:</span>
                                            <span class="account-inline-value">@(user.GroupName ?? "—")</span>
                                        </div>

                                        <div class="account-inline-separator"></div>

                                        <div class="account-inline-info">
                                            <span class="account-inline-label">Курс:</span>
                                            <span class="account-inline-value">@(user.Course?.ToString() ?? "—")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="account-inline-info">
                                            <span class="account-inline-label">Статус:</span>
                                            <span class="account-inline-value">@roleDescription</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="account-card-actions">
                                <button type="button" class="admin-secondary-button edit-account-button">
                                    Редактировать
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <div class="admin-panel" id="logs-panel">
                <div class="admin-panel-header">
                    <div>
                        <h2>Журнал системы</h2>
                        <p>Выберите нужный тип логов.</p>
                    </div>
                </div>

                <div class="admin-subtabs">
                    <button type="button" class="admin-subtab-button active" data-console="registered-users-tab">
                        Зарегистрированные пользователи
                    </button>
                    <button type="button" class="admin-subtab-button" data-console="admin-actions-tab">
                        Изменения администраторами
                    </button>
                    <button type="button" class="admin-subtab-button" data-console="user-profile-changes-tab">
                        Изменения данных пользователями
                    </button>
                </div>

                <div class="admin-console-wrapper">
                    <div class="admin-console active" id="registered-users-tab">
                        <div class="admin-console-body">
                            @if (Model.RegisteredUsersLogs.Count == 0)
                            {
                                <div class="admin-console-empty">Пока нет записей.</div>
                            }
                            else
                            {
                                @foreach (var log in Model.RegisteredUsersLogs)
                                {
                                    <div class="admin-console-line">
                                        <span class="admin-console-date">@log.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</span>
                                        <span class="admin-console-text">@log.Description</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="admin-console-footer">
                            <a asp-controller="Admin" asp-action="DownloadLogs" asp-route-category="registered-users" class="admin-console-download-button">
                                Выгрузить .txt
                            </a>
                        </div>
                    </div>

                    <div class="admin-console" id="admin-actions-tab">
                        <div class="admin-console-body">
                            @if (Model.AdminActionsLogs.Count == 0)
                            {
                                <div class="admin-console-empty">Пока нет записей.</div>
                            }
                            else
                            {
                                @foreach (var log in Model.AdminActionsLogs)
                                {
                                    <div class="admin-console-line">
                                        <span class="admin-console-date">@log.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</span>
                                        <span class="admin-console-text"><strong>@(log.ActorFullName ?? "Администратор")</strong>: @log.Description</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="admin-console-footer">
                            <a asp-controller="Admin" asp-action="DownloadLogs" asp-route-category="admin-actions" class="admin-console-download-button">
                                Выгрузить .txt
                            </a>
                        </div>
                    </div>

                    <div class="admin-console" id="user-profile-changes-tab">
                        <div class="admin-console-body">
                            @if (Model.UserProfileChangesLogs.Count == 0)
                            {
                                <div class="admin-console-empty">Пока нет записей.</div>
                            }
                            else
                            {
                                @foreach (var log in Model.UserProfileChangesLogs)
                                {
                                    <div class="admin-console-line">
                                        <span class="admin-console-date">@log.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</span>
                                        <span class="admin-console-text"><strong>@(log.ActorFullName ?? "Пользователь")</strong>: @log.Description</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="admin-console-footer">
                            <a asp-controller="Admin" asp-action="DownloadLogs" asp-route-category="user-profile-changes" class="admin-console-download-button">
                                Выгрузить .txt
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-panel" id="chats-panel">
                <div class="admin-panel-header">
                    <div>
                        <h2>Чаты</h2>
                        <p>Диалоги между всеми ролями системы.</p>
                    </div>
                </div>

                @await Html.PartialAsync("_MessagingWorkspace", Model.Messaging)
            </div>

            <div class="admin-panel" id="notifications-panel">
                <div class="admin-panel-header">
                    <div>
                        <h2>Уведомления</h2>
                        <p>Раздел подготовлен для будущих системных событий.</p>
                    </div>
                </div>

                @await Html.PartialAsync("_NotificationsPanel")
            </div>
        </section>
    </section>
</div>

<div class="admin-modal-backdrop" id="userModalBackdrop">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <div>
                <h2 id="userModalTitle">Редактирование пользователя</h2>
                <p id="userModalSubtitle">Изменение данных пользователя</p>
            </div>
            <button type="button" class="admin-modal-close" id="closeUserModalButton">×</button>
        </div>

        <form asp-controller="Admin" asp-action="SaveUser" method="post" enctype="multipart/form-data" id="adminUserForm" class="admin-user-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" id="modalUserId" />
            <input type="hidden" name="IsCreateMode" id="modalIsCreateMode" value="false" />
            <input type="hidden" name="CurrentAvatarUrl" id="modalCurrentAvatarUrl" />
            <input type="hidden" name="RemoveAvatar" id="modalRemoveAvatar" value="false" />
            <input type="hidden" name="IsActive" id="modalIsActive" value="true" />

            <div class="admin-form-grid">
                <div class="form-group">
                    <label class="form-label" for="modalSurname">Фамилия</label>
                    <input class="form-input" type="text" id="modalSurname" name="Surname" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="modalFirstName">Имя</label>
                    <input class="form-input" type="text" id="modalFirstName" name="FirstName" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="modalPatronymic">Отчество</label>
                    <input class="form-input" type="text" id="modalPatronymic" name="Patronymic" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="modalEmail">Email</label>
                    <input class="form-input" type="email" id="modalEmail" name="Email" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="modalRoleSelect">Роль</label>

                    <select id="modalRoleSelect" name="Role" class="native-select-hidden">
                        <option value="Student">Student</option>
                        <option value="Admin">Admin</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="DepartmentStaff">DepartmentStaff</option>
                    </select>

                    <div class="custom-select" data-target="modalRoleSelect">
                        <button type="button" class="custom-select-trigger">Student</button>
                        <div class="custom-select-menu"></div>
                    </div>
                </div>

                <div class="form-group" id="modalPasswordGroup">
                    <label class="form-label" for="modalPassword">Пароль</label>
                    <input class="form-input" type="password" id="modalPassword" name="Password" />
                </div>

                <div class="form-group" id="modalSpecialtyGroup">
                    <label class="form-label" for="modalSpecialtySelect">Специальность</label>

                    <select id="modalSpecialtySelect" class="native-select-hidden">
                        <option value="">-- выберите специальность --</option>
                    </select>

                    <div class="custom-select" data-target="modalSpecialtySelect">
                        <button type="button" class="custom-select-trigger">-- выберите специальность --</button>
                        <div class="custom-select-menu"></div>
                    </div>
                </div>

                <div class="form-group" id="modalGroupWrapper">
                    <label class="form-label" for="modalGroupSelect">Группа</label>

                    <select id="modalGroupSelect" name="GroupId" class="native-select-hidden">
                        <option value="">-- выберите группу --</option>
                    </select>

                    <div class="custom-select" data-target="modalGroupSelect">
                        <button type="button" class="custom-select-trigger">-- выберите группу --</button>
                        <div class="custom-select-menu"></div>
                    </div>
                </div>

                <div class="form-group" id="modalCourseGroup">
                    <label class="form-label" for="modalCourseDisplay">Курс</label>
                    <input class="form-input" type="text" id="modalCourseDisplay" readonly />
                </div>

                <div class="form-group admin-form-full">
                    <label class="form-label" for="modalAvatarFile">Аватар</label>

                    <div class="file-upload-control">
                        <input type="file" id="modalAvatarFile" name="AvatarFile" accept="image/*" class="file-upload-input" />
                        <label for="modalAvatarFile" class="file-upload-button">Выбрать файл</label>
                        <span class="file-upload-name" id="modalAvatarFileName">Файл не выбран</span>
                    </div>
                </div>
            </div>

            <div class="admin-user-preview-row">
                <div class="admin-user-avatar-preview" id="modalAvatarPreview">AA</div>

                <div class="admin-user-preview-actions">
                    <label class="switch-filter">
                        <input type="checkbox" id="modalActiveSwitch" checked />
                        <span class="switch-slider"></span>
                        <span class="switch-label">Аккаунт активен</span>
                    </label>

                    <button type="button" class="admin-ghost-button" id="removeAvatarButton">
                        Удалить аватар
                    </button>
                </div>
            </div>

            <div class="admin-modal-actions">
                <button type="button" class="admin-ghost-button" id="cancelUserModalButton">
                    Отмена
                </button>
                <button type="submit" class="admin-primary-button">
                    Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_ProfileSettingsModal", Model.CurrentUser)

<div class="admin-modal-backdrop" id="restoreConfirmModalBackdrop">
    <div class="admin-modal admin-modal-compact">
        <div class="admin-modal-header">
            <div>
                <h2>Подтвердите восстановление</h2>
                <p>База данных будет заменена содержимым выбранной резервной копии.</p>
            </div>
            <button type="button" class="admin-modal-close" id="closeRestoreConfirmModalButton">×</button>
        </div>

        <div class="admin-modal-body-text">
            После восстановления текущие пользователи, практики, назначения, журналы и чаты вернутся к состоянию из backup-файла. Изменения, сделанные после создания этой копии, будут потеряны.
        </div>

        <div class="admin-modal-actions">
            <button type="button" class="admin-ghost-button" id="cancelRestoreConfirmButton">Отмена</button>
            <button type="button" class="admin-danger-button" id="approveRestoreConfirmButton">Восстановить базу</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/student-profile.js"></script>
    <script src="~/js/admin.js"></script>
}
